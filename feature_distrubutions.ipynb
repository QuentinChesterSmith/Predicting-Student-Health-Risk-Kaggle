import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

import warnings
warnings.filterwarnings("ignore")

training_data = pd.read_csv(r'/kaggle/input/competitions/playground-series-s6e7/train.csv')

# patient types
at_risk = training_data[training_data["health_condition"] == "at-risk"]
unhealthy = training_data[training_data["health_condition"] == "unhealthy"]
fit = training_data[training_data["health_condition"] == "fit"]

feature = "sleep_duration"


#at risk
plt.figure(figsize=(10, 5))
sns.histplot(data=at_risk, x=feature)
plt.title("At Risk")
plt.show()

#unhealthy
plt.figure(figsize=(10, 5))
sns.histplot(data=unhealthy, x=feature)
plt.title("Unhealthy")
plt.show()


#fit
plt.figure(figsize=(10, 5))
sns.histplot(data=fit, x=feature)
plt.title("Fit")
plt.show()


